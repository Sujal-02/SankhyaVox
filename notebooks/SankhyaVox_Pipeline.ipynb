    "---\n",
    "## 🗺️ Step 2: Text Maps & Augmentation Engine"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Augmentation engine: 30 variants per voice\n",
      "✅ 13 single tokens + 27 multi-word sequences\n"
     ]
    }
   ],
   "source": [
    "# Devanagari text for single-token TTS\n",
    "DEVANAGARI_MAP = {\n",
    "    \"shunya\": \"शून्य\", \"eka\": \"एक\", \"dvi\": \"द्वि\", \"tri\": \"त्रि\",\n",
    "    \"catur\": \"चतुर\", \"pancha\": \"पञ्च\", \"shat\": \"षट\", \"sapta\": \"सप्त\",\n",
    "    \"ashta\": \"अष्ट\", \"nava\": \"नव\", \"dasha\": \"दश\",\n",
    "    \"vimsati\": \"विंशति\", \"shata\": \"शत\",\n",
    "}\n",
    "\n",
    "# Multi-word sequences for double-digit training (CRITICAL!)\n",
    "SEQUENCE_MAP = {\n",
    "    \"dasha_eka\": \"दश एक\", \"dasha_dvi\": \"दश द्वि\", \"dasha_tri\": \"दश त्रि\",\n",
    "    \"dasha_catur\": \"दश चतुर\", \"dasha_pancha\": \"दश पञ्च\", \"dasha_shat\": \"दश षट\",\n",
    "    \"dasha_sapta\": \"दश सप्त\", \"dasha_ashta\": \"दश अष्ट\", \"dasha_nava\": \"दश नव\",\n",
    "    \"vimsati_eka\": \"विंशति एक\", \"vimsati_pancha\": \"विंशति पञ्च\",\n",
    "    \"vimsati_sapta\": \"विंशति सप्त\", \"vimsati_nava\": \"विंशति नव\",\n",
    "    \"tri_dasha\": \"त्रि दश\", \"tri_dasha_pancha\": \"त्रि दश पञ्च\",\n",
    "    \"catur_dasha\": \"चतुर दश\", \"catur_dasha_dvi\": \"चतुर दश द्वि\",\n",
    "    \"pancha_dasha\": \"पञ्च दश\", \"pancha_dasha_sapta\": \"पञ्च दश सप्त\",\n",
    "    \"shat_dasha\": \"षट दश\", \"shat_dasha_tri\": \"षट दश त्रि\",\n",
    "    \"sapta_dasha\": \"सप्त दश\", \"sapta_dasha_dvi\": \"सप्त दश द्वि\",\n",
    "    \"ashta_dasha\": \"अष्ट दश\", \"ashta_dasha_pancha\": \"अष्ट दश पञ्च\",\n",
    "    \"nava_dasha\": \"नव दश\", \"nava_dasha_nava\": \"नव दश नव\",\n",
    "}\n",
    "\n",
    "# Augmentation matrix\n",
    "PITCH_STEPS  = [-4, -2, 0, 2, 4]     # 5 pitch variants\n",
    "SPEED_RATES  = [0.85, 1.0, 1.15]      # 3 speed variants\n",
    "NOISE_LEVELS = [0.0, 0.003]            # clean + noise\n",
    "\n",
    "generated_count = 0\n",
    "\n",
    "def augment_and_save(audio, sr, token, var_name):\n",
    "    \"\"\"Apply augmentation matrix to single-token audio.\"\"\"\n",
    "    global generated_count\n",
    "    trimmed, _ = librosa.effects.trim(audio, top_db=30)\n",
    "    if len(trimmed) > int(sr * 0.1): audio = trimmed\n",
    "    for p in PITCH_STEPS:\n",
    "        for s in SPEED_RATES:\n",
    "            for n in NOISE_LEVELS:\n",
    "                y = audio.copy()\n",
    "                if s != 1.0: y = librosa.effects.time_stretch(y=y, rate=s)\n",
    "                if p != 0: y = librosa.effects.pitch_shift(y=y, sr=sr, n_steps=p)\n",
    "                if n > 0: y = y + np.random.normal(0, n, len(y)).astype(np.float32)\n",
    "                out = os.path.join(RAW_SYNTH_DIR, f\"synth_{var_name}_p{p}_s{int(s*100)}_n{int(n*10000)}_{token}.wav\")\n",
    "                sf.write(out, y.astype(np.float32), sr)\n",
    "                try:\n",
    "                    process_file(out, os.path.join(str(FEATURE_DIR), f\"synth_{var_name}\"))\n",
    "                    generated_count += 1\n",
    "                except: pass\n",
    "\n",
    "def augment_sequence(audio, sr, tokens, var_name):\n",
    "    \"\"\"Split multi-word audio into individual token segments + augment.\"\"\"\n",
    "    global generated_count\n",
    "    trimmed, _ = librosa.effects.trim(audio, top_db=30)\n",
    "    if len(trimmed) > int(sr * 0.1): audio = trimmed\n",
    "    n_tok = len(tokens)\n",
    "    for p in PITCH_STEPS:\n",
    "        for s in SPEED_RATES:\n",
    "            for n in NOISE_LEVELS:\n",
    "                y = audio.copy()\n",
    "                if s != 1.0: y = librosa.effects.time_stretch(y=y, rate=s)\n",
    "                if p != 0: y = librosa.effects.pitch_shift(y=y, sr=sr, n_steps=p)\n",
    "                if n > 0: y = y + np.random.normal(0, n, len(y)).astype(np.float32)\n",
    "                seg = len(y) // n_tok\n",
    "                for i, tok in enumerate(tokens):\n",
    "                    chunk = y[i*seg : (i+1)*seg if i < n_tok-1 else len(y)]\n",
    "                    out = os.path.join(RAW_SYNTH_DIR, f\"seq_{var_name}_p{p}_s{int(s*100)}_n{int(n*10000)}_{tok}.wav\")\n",
    "                    sf.write(out, chunk.astype(np.float32), sr)\n",
    "                    try:\n",
    "                        process_file(out, os.path.join(str(FEATURE_DIR), f\"seq_{var_name}\"))\n",
    "                        generated_count += 1\n",
    "                    except: pass\n",
    "\n",
    "augs = len(PITCH_STEPS) * len(SPEED_RATES) * len(NOISE_LEVELS)\n",
    "print(f\"✅ Augmentation engine: {augs} variants per voice\")\n",
    "print(f\"✅ {len(DEVANAGARI_MAP)} single tokens + {len(SEQUENCE_MAP)} multi-word sequences\")"
   ]
  },
